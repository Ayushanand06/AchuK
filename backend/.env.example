# Copy this file to .env and fill in the values you have.
# The app runs without Mappls keys — map pins/heatmap are computed locally;
# only geocoding / nearby-police / route APIs need credentials.

# ── Mappls (MapMyIndia) credentials — https://apis.mappls.com ──────────────────
# A single static REST key is all that's needed (geocode/nearby/route/distance
# use it directly in the URL path). Paste it here:
MAPMYINDIA_API_KEY=
# OAuth client id/secret are NOT required when using a static key — leave blank.
MAPMYINDIA_CLIENT_ID=
MAPMYINDIA_CLIENT_SECRET=

# ── Optional overrides (sensible defaults exist) ───────────────────────────────
# YOLO_CONF_THRESHOLD=0.45
# YOLO_IOU_THRESHOLD=0.45
# INFERENCE_IMGSZ=640
# LIVE_STRIDE=20
# DEDUP_COOLDOWN_SEC=10

# Comma-separated allowed CORS origins; "*" allows all (dev only).
CORS_ORIGINS=*
